<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="#F8F9FA"
    tools:context=".ChucNang1Activity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TÍNH CHU VI &amp; DIỆN TÍCH"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#009688"
        android:gravity="center"
        android:layout_marginBottom="30dp" />

    <EditText
        android:id="@+id/edtChieuDai"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Nhập chiều dài (m)"
        android:inputType="numberDecimal"
        android:textSize="18sp"
        android:layout_marginBottom="15dp" />

    <EditText
        android:id="@+id/edtChieuRong"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Nhập chiều rộng (m)"
        android:inputType="numberDecimal"
        android:textSize="18sp"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnTinhToan"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="TÍNH TOÁN"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#009688"
        app:cornerRadius="10dp"
        android:layout_marginBottom="30dp" />

    <TextView
        android:id="@+id/tvChuVi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chu vi: "
        android:textSize="20sp"
        android:textColor="#2C3E50"
        android:textStyle="bold"
        android:layout_marginBottom="15dp" />

    <TextView
        android:id="@+id/tvDienTich"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Diện tích: "
        android:textSize="20sp"
        android:textColor="#2C3E50"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnQuayLai"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="QUAY LẠI TRANG CHỦ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#7F8C8D"
        app:cornerRadius="10dp"
        android:onClick="quayLaiTrangChu" />

</LinearLayout>