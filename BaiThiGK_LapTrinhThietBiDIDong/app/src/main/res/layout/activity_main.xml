<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="#F8F9FA"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvTieuDe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENU CHỨC NĂNG"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:letterSpacing="0.05"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnChucNang1"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#009688"
        android:elevation="5dp"
        android:onClick="moChucNang1"
        android:text="1. CHỨC NĂNG 1"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="15dp" />

    <Button
        android:id="@+id/btnChucNang2"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        android:text="2. CHỨC NĂNG 2"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3F51B5"
        app:cornerRadius="15dp"
        android:elevation="5dp"
        android:onClick="moChucNang2"/>

    <Button
        android:id="@+id/btnChucNang3"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="20dp"
        android:text="3. CHỨC NĂNG 3"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        app:cornerRadius="15dp"
        android:elevation="5dp"
        android:onClick="moChucNang3"/>

    <Button
        android:id="@+id/btnChucNang4"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="4. CHỨC NĂNG 4"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#9C27B0"
        app:cornerRadius="15dp"
        android:elevation="5dp"
        android:onClick="moChucNang4"/>

</LinearLayout>